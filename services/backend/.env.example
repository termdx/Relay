# Relay backend — v0.1 configuration

# HTTP port
PORT=3000

# Public base URL used to build client approval magic links.
# In production this is the reachable host; locally the API serves the page too.
PUBLIC_BASE_URL=http://localhost:3000

# Postgres — the system of record. Required. `relay up` generates this for you.
# For standalone local dev, start one with pgvector included:
#   docker run -d --name relay-pg -p 5432:5432 \
#     -e POSTGRES_USER=relay -e POSTGRES_PASSWORD=relay -e POSTGRES_DB=relay \
#     pgvector/pgvector:pg16
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# Signing key for desktop session tokens. Required. `relay up` generates and
# injects this per workspace; for standalone dev use any long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=
JWT_TTL=7d

# AI provider for the draft generator: stub (default, no network) | gemini
AI_PROVIDER=stub
# Required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Not yet wired in v0.1 (stub in use) ---
# GITHUB_TOKEN=                 # for the real GitHub issue publisher
