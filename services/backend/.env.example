# Relay backend — v0.1 configuration

# HTTP port
PORT=3000

# Public base URL used to build client approval magic links.
# In production this is the reachable host; locally the API serves the page too.
PUBLIC_BASE_URL=http://localhost:3000

# SQLite database file (v0.1). Swap to Postgres before real data lands.
DATABASE_PATH=relay.dev.sqlite

